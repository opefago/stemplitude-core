# Copy to ``backend/.env`` (same folder as this example). Settings load that file
# regardless of shell cwd; Docker Compose ``env_file: .env`` also means this path.
#
# ── Application ──────────────────────────────────────────────
APP_NAME=STEMplitude
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Base URL for Stripe Checkout / Connect return redirects (no trailing slash). Default matches Vite dev.
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://stem:stem@localhost:5432/stemplitude

# ── Redis ────────────────────────────────────────────────────
# Local uvicorn on the host: localhost is fine.
REDIS_URL=redis://localhost:6379/0
# Docker Compose (api / celery_*): compose sets redis://${COMPOSE_REDIS_HOST:-host.docker.internal}:6379/*
# Override if you use the in-stack redis service: COMPOSE_REDIS_HOST=redis
# COMPOSE_REDIS_HOST=redis

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── S3 / R2 Storage (LocalStack for dev, Cloudflare R2 for prod) ──
S3_ENDPOINT_URL=http://localhost:4566
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=stemplitude-assets
S3_REGION=us-east-1

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# Optional (APP_ENV=development only): if plan rows lack stripe_price_id_*, checkout uses these test Price IDs
STRIPE_DEV_FALLBACK_PRICE_MONTHLY=
STRIPE_DEV_FALLBACK_PRICE_YEARLY=
# Stripe Connect (tenant → student/parent payments). Turn on Connect in Stripe Dashboard → Connect → Get started.
# Member onboarding uses your platform STRIPE_SECRET_KEY only. Optional: Connect OAuth client ID (ca_…) if you use Stripe’s OAuth flow elsewhere.
STRIPE_CONNECT_CLIENT_ID=
# Webhook endpoint (Stripe Dashboard → Developers → Webhooks): POST {API_BASE}/api/v1/subscriptions/webhook
# Use the same endpoint for the platform account and enable “Connect” so events include connected account IDs (event.account).
# Platform events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, invoice.paid
# Connect (member billing): also invoice.payment_failed, invoice.upcoming, account.updated

# ── PayPal (optional — subscription checkout not wired yet) ───
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ── Email – Postmark ────────────────────────────────────────
# Tokens here are used when email_providers.config in the DB omits them.
# Enable the provider in Platform → Email (or PATCH /platform/email/providers).
POSTMARK_SERVER_TOKEN=
# From domain contact.stemplitude.com (verify sender in Postmark / DNS)
POSTMARK_SENDER_EMAIL=info@contact.stemplitude.com

# ── Email – Mailgun ─────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Email – Amazon SES ──────────────────────────────────────
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
AWS_SES_SENDER_EMAIL=

# Global default when provider DB config omits sender_email
EMAIL_DEFAULT_SENDER=info@contact.stemplitude.com
# Optional: HTTPS URL to a PNG/GIF logo for HTML emails (many clients block SVG)
EMAIL_BRAND_LOGO_URL=
# Optional HTML email theme (hex colors, px sizes). Empty = default STEMplitude palette.
# EMAIL_THEME_PRIMARY=#059669
# EMAIL_THEME_PAGE_BG=#f1f5f9
# EMAIL_THEME_CARD_BG=#ffffff
# EMAIL_THEME_FONT_STACK=-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif

# Public API origin for signed unsubscribe links + Gmail/Yahoo one-click (RFC 8058). No trailing slash.
# Scheme + host[:port] only (e.g. http://localhost:8000). Do not add /api/v1 — paths are appended automatically.
# Production: HTTPS URL where this API is reachable.
EMAIL_PUBLIC_BASE_URL=

# Transactional footer — see app/email/templates.py _compliance_footer_html (omit vars to omit blocks).
# EMAIL_FOOTER_ADDRESS=5900 Example Ave, City ST 12345, USA
# EMAIL_FOOTER_WHY_RECEIVING=
# Optional static preferences URL (shown for auth/security-only mail when set).
# EMAIL_UNSUBSCRIBE_URL=https://yoursite.com/app/settings
# EMAIL_SOCIAL_WEBSITE_URL=https://stemplitude.com
EMAIL_UNSUBSCRIBE_URL=
EMAIL_SOCIAL_WEBSITE_URL=
EMAIL_SOCIAL_INSTAGRAM_URL=
EMAIL_SOCIAL_LINKEDIN_URL=
EMAIL_SOCIAL_X_URL=
EMAIL_SOCIAL_FACEBOOK_URL=
EMAIL_SOCIAL_TIKTOK_URL=
EMAIL_SOCIAL_YOUTUBE_URL=

# ── Email – SendGrid ────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_SENDER_EMAIL=info@contact.stemplitude.com
SENDGRID_BASE_URL=https://api.sendgrid.com

# ── Email – Resend ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_SENDER_EMAIL=info@contact.stemplitude.com
RESEND_BASE_URL=https://api.resend.com

# ── Email webhooks (hard bounces + spam complaints → block all mail to that address) ──
# Register in each provider dashboard. Paths (no trailing slash on API base):
#   POST {API_BASE}/api/v1/webhooks/email/postmark   — set HTTP Basic or send Authorization: Bearer …
#   POST {API_BASE}/api/v1/webhooks/email/sendgrid   — enable “Signed Event Webhook”, paste public key below
#   POST {API_BASE}/api/v1/webhooks/email/resend     — paste Svix signing secret (requires ``svix`` in requirements)
EMAIL_WEBHOOK_BEARER_TOKEN=
EMAIL_WEBHOOK_BASIC_USER=
EMAIL_WEBHOOK_BASIC_PASSWORD=
# Public key body only (between BEGIN/END), from SendGrid Event Webhook security settings.
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=
RESEND_WEBHOOK_SECRET=

# ── Flagsmith (feature flags) ───────────────────────────────
FLAGSMITH_API_KEY=
FLAGSMITH_API_URL=https://edge.api.flagsmith.com/api/v1/

# ── Celery (background jobs) ────────────────────────────────
# Invitations, classroom emails, and notification email dispatch use the worker.
# From backend/: celery -A workers.celery_app worker -l info
# Same host as REDIS_URL (host.docker.internal when workers run in Compose against host Redis).
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# true = run .delay() tasks inside the API process (no worker). Handy for local mail tests only.
CELERY_TASK_ALWAYS_EAGER=false

# ── In-app notifications (cron.cleanup_notifications) ───────
# 0 = disable that part (time-based deletion or per-recipient cap)
NOTIFICATION_RETENTION_DAYS=90
NOTIFICATION_MAX_PER_RECIPIENT=500

# ── Email delivery logs (cron.cleanup_email_logs) ────────────
# Rows older than this are purged in batches. 0 = disable (not recommended at volume).
EMAIL_LOG_RETENTION_DAYS=90

# ── Orphan blob cleanup (cron.cleanup_orphan_blobs) ──────────
# true = list only, do not delete from S3/R2
BLOB_ORPHAN_CLEANUP_DRY_RUN=false

# ── Super Admin bootstrap (one-time setup) ──────────────────
# Used by: python -m app.commands.create_superadmin
# Remove or leave blank after the initial account is created.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# ── Cardless signup trial (onboard) ───────────────────────────
# Requires plan slug in DB (seed from config/plan_registry.json).
TRIAL_ENABLED=true
TRIAL_PLAN_SLUG=trial-evaluation
# 0 = use plan.trial_days from database (fallback 14)
TRIAL_DURATION_DAYS=14
TRIAL_MAX_ONBOARDS_PER_IP_PER_DAY=20
TRIAL_MAX_ONBOARD_ATTEMPTS_PER_EMAIL_HOUR=10
TRIAL_BLOCK_DISPOSABLE_EMAIL=true
# Comma-separated extra disposable domains (optional)
TRIAL_DISPOSABLE_EMAIL_DOMAINS_EXTRA=
