# Google reCAPTCHA Site Key (get from https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_SITE_KEY=your_site_key_here

# API Configuration
VITE_API_URL=your_backend_url_here
# Must match backend PUBLIC_HOST_BASE_DOMAIN so the SPA knows when it is on a tenant subdomain (student login).
# Production example: stemplitude.com. Local dev: localhost (for http://{tenant}.localhost:5173).
VITE_PUBLIC_HOST_BASE_DOMAIN=
